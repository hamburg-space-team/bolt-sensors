CompileFlags:
  Add:
    - -std=gnu++2b
    - -xc++
    - -stdlib=libc++
    - -Isensor-interfaces/include
    - -Isensor-drivers/include
    - -Ihardware-adapters/include
  Remove:
    - -masm-syntax-unified # ARM GCC-only flag, not recognized by clangd/clang
    - -masm=* # same family
    - --specs=* # linker flag leaking into compile commands
    - -fstack-usage # GCC-only codegen flag
    - -std=* # replaced by Add above
---
# Suppress diagnostics in CubeMX-generated, CMSIS RTE, host build, and
# CMake-fetched dependency folders. clangd descends into these by default
# and they emit noise we never want to fix (vendor code, broken .clang-tidy
# in third-party deps, ARM-only flags clang can't parse, etc.).
If:
  PathMatch:
    - ".*generated/.*"
    - ".*RTE/.*"
    - ".*/build/.*"
    - ".*/vendor/.*"
Diagnostics:
  Suppress:
    - "*"
